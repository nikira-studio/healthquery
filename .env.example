# HealthQuery local environment template

DB_PATH=/app/data/healthquery.db
HEALTHQUERY_INGEST_TOKEN=change-me-ingest
HEALTHQUERY_READ_TOKEN=change-me-read
HEALTHQUERY_AUTH_HEADER=X-Webhook-Token
HEALTHQUERY_LOG_LEVEL=INFO

# Optional LLM settings for reports / Ask
# The Ask tab and LLM-rewritten reports are disabled when these are blank.
# Any OpenAI-compatible endpoint works:
#   OpenAI:  HEALTHQUERY_LLM_BASE_URL=https://api.openai.com/v1
#            HEALTHQUERY_LLM_MODEL=gpt-4o-mini
#            HEALTHQUERY_LLM_API_KEY=sk-...
#   Ollama:  HEALTHQUERY_LLM_BASE_URL=http://localhost:11434/v1
#            HEALTHQUERY_LLM_MODEL=llama3
#            HEALTHQUERY_LLM_API_KEY=   (leave blank)
HEALTHQUERY_LLM_BASE_URL=
HEALTHQUERY_LLM_MODEL=
HEALTHQUERY_LLM_API_KEY=
HEALTHQUERY_LLM_TIMEOUT_SECONDS=60

# Optional REST-backed MCP server
HEALTHQUERY_BASE_URL=http://localhost:3135
